# API Configuration - PRODUCTION
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_API_TIMEOUT=30000

# Environment
NODE_ENV=production
NEXT_PUBLIC_ENV=production

# Debug & logging (disable in production)
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_LOG_LEVEL=error

# Feature Flags
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SEARCH=true

# Authentication
NEXT_PUBLIC_AUTH_TOKEN_EXPIRY=7d
NEXT_PUBLIC_AUTH_REFRESH_TOKEN_EXPIRY=30d

# UI & Appearance
NEXT_PUBLIC_APP_NAME=ITMAGNET
NEXT_PUBLIC_APP_DESCRIPTION=Intelligent Support Cockpit
NEXT_PUBLIC_BRAND_COLOR=#2563eb

# Performance
NEXT_PUBLIC_QUERY_CACHE_TIME=600000
NEXT_PUBLIC_QUERY_STALE_TIME=300000
NEXT_PUBLIC_DEBOUNCE_DELAY=500

# API Rate Limiting (client-side)
NEXT_PUBLIC_API_RATE_LIMIT=100
NEXT_PUBLIC_API_RATE_LIMIT_WINDOW=60000

# Monitoring & Analytics
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token
NEXT_PUBLIC_GA_ID=your-google-analytics-id
