# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
NEXT_PUBLIC_API_TIMEOUT=30000

# Environment
NODE_ENV=development
NEXT_PUBLIC_ENV=development

# Debug & logging
NEXT_PUBLIC_DEBUG=true
NEXT_PUBLIC_LOG_LEVEL=debug

# Feature Flags
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SEARCH=true

# Authentication
NEXT_PUBLIC_AUTH_JWT_SECRET_KEY=your-secret-key-here
NEXT_PUBLIC_AUTH_TOKEN_EXPIRY=7d
NEXT_PUBLIC_AUTH_REFRESH_TOKEN_EXPIRY=30d
NEXT_PUBLIC_AUTH_STORAGE_KEY=itmagnet_access_token
NEXT_PUBLIC_AUTH_REFRESH_STORAGE_KEY=itmagnet_refresh_token

# UI & Appearance
NEXT_PUBLIC_APP_NAME=ITMAGNET
NEXT_PUBLIC_APP_DESCRIPTION=Intelligent Support Cockpit
NEXT_PUBLIC_BRAND_COLOR=#2563eb

# Performance
NEXT_PUBLIC_QUERY_CACHE_TIME=300000
NEXT_PUBLIC_QUERY_STALE_TIME=60000
NEXT_PUBLIC_DEBOUNCE_DELAY=300

# API Rate Limiting (client-side)
NEXT_PUBLIC_API_RATE_LIMIT=100
NEXT_PUBLIC_API_RATE_LIMIT_WINDOW=60000

# Monitoring & Analytics (Optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_GA_ID=
